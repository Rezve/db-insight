# =============================================================================
# DB Insight — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to source control.
# =============================================================================


# -----------------------------------------------------------------------------
# SESSION SECRET (required)
# -----------------------------------------------------------------------------
# Used to encrypt the session cookie. Must be at least 32 characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-this-with-a-random-32-char-or-longer-secret


# -----------------------------------------------------------------------------
# Database Connection Pre-fill (optional)
# -----------------------------------------------------------------------------
# These variables auto-populate the connection form so you don't have to
# re-enter credentials every time you open the app.
#
# How it works:
#   - Values are read server-side only and sent to the browser just to fill
#     the form fields — the same as if you typed them manually.
#   - Fields remain fully editable; you can always override them in the UI.
#   - Restart the dev server (npm run dev) after changing these values.
#   - If DB_SERVER is not set, the form starts blank and a tip is shown
#     explaining how to configure this feature.
# -----------------------------------------------------------------------------

# Server address. Supported formats:
#   hostname              e.g. myserver.database.windows.net
#   hostname\INSTANCE     e.g. localhost\SQLEXPRESS
#   hostname,port         e.g. localhost,1433
# DB_SERVER=localhost\SQLEXPRESS

# Authentication mode: "sql" (default) or "windows"
#   sql     — SQL Server Authentication (username + password required)
#   windows — Windows / Integrated Authentication (uses the process credentials;
#             username and password are ignored)
# DB_AUTH_MODE=sql

# SQL Server login username (required when DB_AUTH_MODE=sql)
# DB_USERNAME=sa

# SQL Server login password (required when DB_AUTH_MODE=sql)
# DB_PASSWORD=your-password

# TCP port (optional — omit to use the default 1433, or when the instance
# name is embedded in DB_SERVER as "host\INSTANCE")
# DB_PORT=

# Encrypt the connection (true/false, default: false)
# Set to true for Azure SQL Database or any remote server.
# DB_ENCRYPT=false

# Trust the server's TLS certificate without validation (true/false, default: true)
# Set to false in production when using a properly signed certificate.
# DB_TRUST_SERVER_CERTIFICATE=true

# Default database to pre-select after fetching the database list (optional)
# If omitted, the first non-system database is selected automatically.
# DB_DATABASE=MyDatabase
